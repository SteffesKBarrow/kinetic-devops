#!/usr/bin/env python
"""
scripts/hooks/pre-commit - packaged pre-commit hook for Kinetic SDK

This file is the repository-tracked copy of the pre-commit hook. Developers
should install it into their local `.git/hooks/pre-commit` or set
`git config core.hooksPath scripts/hooks` to use hooks from the repo.

Usage:
  # To install locally
  copy scripts\hooks\pre-commit .git\hooks\pre-commit
  # Make executable if on Unix: chmod +x .git/hooks/pre-commit

When run, this script executes the SDK test runner and blocks commits if
tests fail.
"""
import subprocess
import sys
from pathlib import Path


def run_pre_commit_checks():
    """Run all pre-commit checks."""
    print("=" * 70)
    print("PRE-COMMIT: Running Kinetic SDK test suite...")
    print("=" * 70)
    
    # Get repo root
    repo_root = Path(__file__).parent.parent
    
    # Run tests using the CLI test runner
    result = subprocess.run(
        [sys.executable, "-m", "kinetic_devops.cli.test_runner"],
        cwd=str(repo_root),
        capture_output=False
    )
    
    if result.returncode == 0:
        print("\n" + "=" * 70)
        print("PRE-COMMIT: All tests passed. Commit allowed.")
        print("=" * 70)
        return 0
    else:
        print("\n" + "=" * 70)
        print("PRE-COMMIT: Tests failed. Commit blocked.")
        print("=" * 70)
        return 1


if __name__ == '__main__':
    sys.exit(run_pre_commit_checks())
